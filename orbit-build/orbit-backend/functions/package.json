{
  "name": "orbit-functions",
  "description": "Orbit Firebase Cloud Functions — conversation engine, tax, leaderboard",
  "version": "2.0.0",
  "engines": { "node": "20" },
  "main": "src/index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions",
    "lint": "eslint src/ --ext .js",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.9.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"]
  },
  "private": true
}
